# Smart Classroom AI — Backend Environment Variables
# Copy this file to .env and edit values as needed.
# DO NOT commit .env to version control.

# Flask
FLASK_DEBUG=true
SECRET_KEY=change-me-in-production

# Camera (0 = default webcam / PiCamera on RPi)
CAMERA_INDEX=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=15

# Face recognition
FACE_TOLERANCE=0.55

# Attendance defaults (minutes)
CLASS_DURATION=60
ATTENDANCE_WINDOW=10

# IoT / GPIO — set to true only on Raspberry Pi with wiring
GPIO_ENABLED=false
GPIO_LIGHTS_PIN=17
GPIO_FANS_PIN=27

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173
